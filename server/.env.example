# Copy to .env and fill in real values for persistent, non-dev storage.

# If unset in a non-production NODE_ENV, the app boots an in-memory MongoDB
# instance automatically so it runs with zero setup. Set this to a real
# MongoDB (local install or Atlas) connection string for persistent data.
# MONGODB_URI=mongodb://127.0.0.1:27017/phoenix-vapers

PORT=4000
NODE_ENV=development

JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

WEB_ORIGIN=http://localhost:3000

# Optional: leave unset to use the built-in Mock payment adapter (auto-approves).
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
